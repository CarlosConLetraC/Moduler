{
  "cells": [
    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "%matplotlib inline\n"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "df = pd.read_csv('data/train.csv')\n",
        "numeric_cols = df.select_dtypes(include=np.number).columns.tolist()\n",
        "if 'log_price' in numeric_cols:\n",
        "    numeric_cols.remove('log_price')\n",
        "df.head()"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Histogramas\n",
        "for col in numeric_cols + ['log_price']:\n",
        "    plt.figure(figsize=(6,4))\n",
        "    sns.histplot(df[col].dropna(), bins=30, kde=True)\n",
        "    plt.title(f'Histograma de {col}')\n",
        "    plt.show()"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Boxplots\n",
        "for col in numeric_cols + ['log_price']:\n",
        "    plt.figure(figsize=(6,4))\n",
        "    sns.boxplot(x=df[col].dropna(), color='lightblue')\n",
        "    plt.title(f'Boxplot de {col}')\n",
        "    plt.show()"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Scatter plots\n",
        "for col in numeric_cols:\n",
        "    plt.figure(figsize=(6,4))\n",
        "    sns.scatterplot(x=df[col], y=df['log_price'])\n",
        "    plt.title(f'Scatter: log_price vs {col}')\n",
        "    plt.show()"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Heatmap de correlaciones\n",
        "plt.figure(figsize=(10,8))\n",
        "corr_matrix = df[numeric_cols + ['log_price']].corr()\n",
        "sns.heatmap(corr_matrix, annot=True, fmt='.2f', cmap='coolwarm')\n",
        "plt.title('Mapa de calor de correlaciones')\n",
        "plt.show()"
      ]
    }
  ]
}
